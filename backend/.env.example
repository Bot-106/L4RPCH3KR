# MongoDB — localhost is intentional: Mongo runs on the same host as the backend.
MONGO_URL=mongodb://localhost:27017
MONGO_DB=larpchekr

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=<generate with: openssl rand -hex 32>

# Enable fixture/stub mode (no real ASR, LLM, or DB required for basic tests).
FIXTURE_MODE=false

# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=<your OpenAI API key>
ANTHROPIC_API_KEY=                    # leave blank if using openai

# LLM model name (used by the selected provider)
LLM_MODEL=gpt-4o-mini

# Whisper ASR settings
WHISPER_MODEL=base.en
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

# Minimum audio buffer before running ASR (seconds)
ASR_CHUNK_SECONDS=3.0

# CORS — comma-separated list of allowed origins.
# Default covers the web-phone (:3000) and dashboard (:3001) on the Tailscale backend host.
CORS_ORIGINS=http://100.76.124.67:3000,http://100.76.124.67:3001

# Magic-link email sender (used by resend.com or postmark)
MAGIC_LINK_FROM=noreply@larpchekr.app
RESEND_API_KEY=<your Resend API key>

# GitHub OAuth — used for linking attendee GitHub profiles (not for auth)
GITHUB_OAUTH_CLIENT_ID=<your GitHub OAuth app client ID>
GITHUB_OAUTH_CLIENT_SECRET=<your GitHub OAuth app client secret>

# Storage backend: "local" (dev) or "s3" (prod)
STORAGE_BACKEND=local
