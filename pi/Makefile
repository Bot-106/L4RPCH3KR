.PHONY: contracts test lint run

# Regenerate generated types from contracts/schemas/.
# ws_envelope.py is generated by datamodel-codegen from ws-envelope.schema.json.
# ws_events.py is maintained manually because datamodel-codegen 0.25.6 cannot
# process the full schema directory (profile-facts.schema.json has a hyphen in
# its filename, producing invalid Python: `from ..profile-facts import ...`).
# Fix: rename profile-facts.schema.json → profile_facts.schema.json in contracts/,
# then replace the manual file with a generated one.
contracts:
	datamodel-codegen \
		--input ../contracts/schemas/ws-envelope.schema.json \
		--input-file-type jsonschema \
		--output larpchekr/contracts/generated/ws_envelope.py \
		--output-model-type pydantic_v2.BaseModel \
		--target-python-version 3.11
	@echo "ws_envelope.py regenerated."
	@echo "NOTE: ws_events.py is manually maintained — see larpchekr/contracts/generated/ws_events.py"

test:
	pytest

lint:
	ruff check .

run:
	python -m larpchekr.main
