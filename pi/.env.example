# Backend connectivity
LARPCHEKR_BACKEND_WS=ws://100.76.124.67:8000/ws/pi
LARPCHEKR_BACKEND_REST=http://100.76.124.67:8000

# Device identity
LARPCHEKR_DEVICE_ID=rpi-001
# On the Pi: /etc/larpchekr/pi_token (requires root to create, then chown pi:pi)
# On macOS/Linux dev: use a writable path, e.g. /tmp/larpchekr/pi_token
LARPCHEKR_PI_TOKEN_PATH=/etc/larpchekr/pi_token

# Logging
LARPCHEKR_LOG_LEVEL=info

# Dev only — set to 1 to run without real hardware (GPIO, camera, mic)
LARPCHEKR_FAKE_HARDWARE=0
