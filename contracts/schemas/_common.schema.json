{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://larpchekr.app/schemas/_common.schema.json",
  "title": "Common types",
  "$defs": {
    "Ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "Crockford base32 ULID, 26 chars."
    },
    "IsoTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "Confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "Severity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "Hedge": {
      "type": "string",
      "enum": ["none", "weak", "strong"]
    },
    "Speaker": {
      "type": "string",
      "enum": ["self", "partner", "unknown"]
    },
    "ConsentStatus": {
      "type": "string",
      "enum": ["pending", "granted", "denied"]
    },
    "ProfileSource": {
      "type": "string",
      "enum": ["github", "linkedin", "resume"]
    }
  }
}
