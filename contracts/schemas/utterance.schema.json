{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://larpchekr.app/schemas/utterance.schema.json",
  "title": "Utterance",
  "type": "object",
  "required": ["id", "session_id", "speaker", "speaker_confidence", "started_at", "ended_at", "text"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "_common.schema.json#/$defs/Ulid" },
    "session_id": { "$ref": "_common.schema.json#/$defs/Ulid" },
    "speaker": { "$ref": "_common.schema.json#/$defs/Speaker" },
    "speaker_confidence": { "$ref": "_common.schema.json#/$defs/Confidence" },
    "started_at": { "$ref": "_common.schema.json#/$defs/IsoTimestamp" },
    "ended_at": { "$ref": "_common.schema.json#/$defs/IsoTimestamp" },
    "text": { "type": "string" },
    "audio_url": { "type": ["string", "null"], "format": "uri" }
  }
}
