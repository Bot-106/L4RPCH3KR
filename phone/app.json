{
  "name": "larpchekr",
  "displayName": "L4RPCH3KR",
  "expo": {
    "name": "L4RPCH3KR",
    "slug": "larpchekr",
    "version": "1.0.0",
    "scheme": "larpchekr",
    "ios": {
      "bundleIdentifier": "app.larpchekr.phone",
      "supportsTablet": false
    },
    "android": {
      "package": "app.larpchekr.phone",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "L4RPCH3KR needs camera access to scan QR codes.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "L4RPCH3KR needs microphone access for voice calibration."
        }
      ]
    ]
  }
}
