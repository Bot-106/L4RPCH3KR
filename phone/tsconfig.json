{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@env": ["./.env.d.ts"]
    },
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "*.d.ts",
    ".env.d.ts",
    "../design/tokens/*.json"
  ]
}
